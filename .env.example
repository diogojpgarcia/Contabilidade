# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Supabase — required. Find these in your Supabase project settings > API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Twelve Data API key — free at https://twelvedata.com
# Enables live stock price quotes + daily change % in the Patrimony tab.
# Free tier: 8 credits/min, 800/day. Leave empty to disable.
# SERVER-SIDE ONLY: usada apenas pelas funções api/ (proxy /api/twelve), nunca no
# cliente — por isso SEM prefixo VITE_ (não vai no bundle). O código também aceita
# VITE_TWELVE_DATA_KEY (legacy) como fallback, mas prefere TWELVE_DATA_KEY.
TWELVE_DATA_KEY=

# CoinGecko is used for crypto prices (no API key needed).
