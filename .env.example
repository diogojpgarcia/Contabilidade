# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Twelve Data API key — free at https://twelvedata.com
# Enables live stock price quotes + daily change % in the Patrimony tab.
# Free tier: 8 credits/min, 800/day. Leave empty to disable.
VITE_TWELVE_DATA_KEY=

# CoinGecko is used for crypto prices (no API key needed).
